# -----------------------------------------------------------------------------
# Shared service defaults
# Used by: api-gateway, identity-service, problem-service, submission-service, worker
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# AWS region used by AWS SDK clients. The local gateway needs this when invoking
# the chat Lambda via boto3. Other services may also use it when talking to AWS.
AWS_REGION=ap-southeast-1

# For local Lambda invocation, provide AWS credentials through env vars,
# AWS_PROFILE, or the standard shared AWS config/credentials files.
# Do not commit secrets here.
# Used by: local api-gateway only, when /api/chat/* invokes a real Lambda.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# -----------------------------------------------------------------------------
# Cognito JWT validation
# Used by: identity-service, problem-service, submission-service
# Not used by: api-gateway, worker
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=ap-southeast-1_example
COGNITO_APP_CLIENT_ID=exampleclientid
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_example
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_example/.well-known/jwks.json

# -----------------------------------------------------------------------------
# Shared data stores
# DATABASE_URL is used by: identity-service, problem-service, submission-service
# REDIS_URL is used by: problem-service
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hexacode:hexacode@postgres:5432/hexacode
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# S3 / MinIO object storage
# Used by:
# - problem-service: problem statements, media, testsets, checker artifacts
# - submission-service: submission artifact reads / future writes
# - worker: testcase/checker reads and compiled checker uploads
# -----------------------------------------------------------------------------
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_BUCKET_PROBLEMS=hexacode-problems
S3_BUCKET_SUBMISSIONS=hexacode-submissions

# -----------------------------------------------------------------------------
# SQS / ElasticMQ judge queue
# Used by:
# - submission-service: enqueue judge jobs
# - worker: poll and process judge jobs
# -----------------------------------------------------------------------------
QUEUE_DRIVER=sqs
SQS_ENDPOINT=http://elasticmq:9324
SQS_JUDGE_QUEUE_URL=http://elasticmq:9324/000000000000/judge-jobs

# -----------------------------------------------------------------------------
# Local gateway HTTP routing
# Used by: api-gateway
# ROUTE_MANIFEST_PATH points to the shared route contract.
# PROBLEM_SERVICE_URL and SUBMISSION_SERVICE_URL are normal HTTP upstreams.
# -----------------------------------------------------------------------------
ROUTE_MANIFEST_PATH=/app/contracts/route-manifest.json
GATEWAY_TIMEOUT_SECONDS=20
PROBLEM_SERVICE_URL=http://problem-service:8000
SUBMISSION_SERVICE_URL=http://submission-service:8000

# -----------------------------------------------------------------------------
# Local gateway -> chat Lambda simulation
# Used by: api-gateway only
# The local gateway invokes this Lambda directly to simulate:
# frontend -> API Gateway HTTP API -> Lambda
# The configured AWS principal must have lambda:InvokeFunction permission.
# -----------------------------------------------------------------------------
CHAT_LAMBDA_FUNCTION_NAME=
CHAT_LAMBDA_QUALIFIER=
CHAT_LAMBDA_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Worker identity / polling behavior
# Used by: worker only
# -----------------------------------------------------------------------------
WORKER_NAME=worker-local-1
WORKER_VERSION=0.1.0
WORKER_POLL_INTERVAL_SECONDS=15

# -----------------------------------------------------------------------------
# Not used from this file: deployed chat Lambda Agent / Knowledge Base config
# These are set on the Lambda itself in AWS, not in the backend containers.
# Examples:
# BEDROCK_AGENT_ID=
# BEDROCK_AGENT_ALIAS_ID=
# BEDROCK_KNOWLEDGE_BASE_ID=
# BEDROCK_AGENT_REGION=
# BEDROCK_AGENT_TIMEOUT_SECONDS=20
# BEDROCK_AGENT_NUMBER_OF_RESULTS=8
# BEDROCK_AGENT_OVERRIDE_SEARCH_TYPE=SEMANTIC
# -----------------------------------------------------------------------------
