# -----------------------------------------------------------------------------
# Frontend public environment
# These values are exposed to the browser by Vite.
# They must point to public endpoints the browser can actually call.
# -----------------------------------------------------------------------------

# Public backend base URL for the browser.
# Example local value: the local thin gateway, not an internal backend service.
# Used by: frontend API client
PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Cognito browser auth
# Used by: custom sign-in / sign-up flow in the frontend
# These are public identifiers, not secrets.
# -----------------------------------------------------------------------------

# Required for the custom Cognito auth form.
PUBLIC_COGNITO_CLIENT_ID=
PUBLIC_COGNITO_REGION=

# Optional:
# - Hosted UI compatibility
# - region inference fallback when PUBLIC_COGNITO_REGION is omitted
PUBLIC_COGNITO_DOMAIN=
PUBLIC_COGNITO_SCOPES=openid email profile

# -----------------------------------------------------------------------------
# Notes
# - Do not put internal backend-to-backend service URLs in this file.
# - Do not use PROBLEM_SERVICE_URL, SUBMISSION_SERVICE_URL, or other container-only
#   addresses here; the browser cannot reach them.
# - INTERNAL_API_BASE_URL is not used by the current frontend runtime and is
#   intentionally omitted to avoid confusion with PUBLIC_API_BASE_URL.
# -----------------------------------------------------------------------------
